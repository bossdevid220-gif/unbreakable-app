<!DOCTYPE html>
<html lang="EN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZENOX - CORE PORTAL</title>
    <style>
        * { margin:0; padding:0; box-sizing:border-box; font-family: system-ui, sans-serif; }
        body { background: #040209; color: #fff; padding: 30px; }
        .container { max-width: 650px; margin: 0 auto; }
        .header { display: flex; justify-content: space-between; align-items: center; padding-bottom: 20px; border-bottom: 2px solid #006EFF; margin-bottom: 30px; }
        .header h1 { color: #FF0055; font-size: 22px; font-weight: 900; letter-spacing: 1px; }
        .logout { background: rgba(255, 0, 85, 0.1); border: 1px solid #FF0055; color: #FF0055; padding: 8px 18px; border-radius: 8px; font-size: 12px; font-weight: 900; text-decoration: none; transition: 0.3s; }
        .logout:hover { background: #FF0055; color: white; }
        .card { background: #0c0919; border-radius: 16px; padding: 25px; border: 1px solid rgba(0, 110, 255, 0.2); margin-bottom: 20px; }
        .card h2 { color: #006EFF; font-size: 16px; font-weight: 900; margin-bottom: 15px; }
        .card p { color: #adacb5; font-size: 14px; margin: 10px 0; font-weight: bold; }
        .value { color: #FF0055; font-family: monospace; }
        .badge { background: #006EFF; color: white; padding: 2px 10px; font-size: 11px; border-radius: 20px; }
        .admin-btn { display: inline-block; margin-top: 15px; background: #FF0055; color: white; padding: 10px 20px; border-radius: 8px; text-decoration: none; font-size: 13px; font-weight: bold; }
    </style>
</head>
<body>
<div class="container">
    <div class="header">
        <h1>ZENOX CORE SYSTEM</h1>
        <a href="/ZENOX-TERMINATE" class="logout">🚪 LOGOUT PORTAL</a>
    </div>
    
    <div class="card">
        <h2>PORTAL ACCESS GRANTED</h2>
        <p>DEVICE SIGNATURE: <span class="value"><%= deviceId %></span></p>
        <p>SYSTEM PRIVILEGE: <span class="value"><%= role.toUpperCase() %></span></p>
        <p>ENCRYPTION GATEWAY: <span class="badge">ACTIVE V5 SECURE</span></p>
        
        <% if (role === 'admin') { %>
            <a href="/ZENOX-MAIN-TERMINAL-ROOT" class="admin-btn">⚙️ GO TO ADMIN TERMINAL</a>
        <% } %>
    </div>
</div>
<script>
    document.addEventListener('contextmenu', e => e.preventDefault());
</script>
</body>
</html>
