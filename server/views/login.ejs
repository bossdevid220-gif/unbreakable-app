<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Unbreakable Login</title>
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body {
            background: #0a0618;
            font-family: system-ui, sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .login-card {
            background: #1a0a3e;
            border-radius: 24px;
            padding: 40px;
            border: 1px solid rgba(139,92,246,0.2);
            width: 100%;
            max-width: 400px;
            box-shadow: 0 20px 60px rgba(139,92,246,0.1);
        }
        .login-card h1 { color: #8B5CF6; font-size: 24px; text-align: center; }
        .login-card .sub { color: #7c6ba0; text-align: center; font-size: 13px; margin-bottom: 24px; }
        .input-group { margin-bottom: 16px; }
        .input-group label { display: block; font-size: 11px; font-weight: 700; color: #7c6ba0; margin-bottom: 6px; }
        .input-group input {
            width: 100%;
            padding: 12px 16px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(139,92,246,0.2);
            border-radius: 10px;
            color: #fff;
            font-size: 14px;
        }
        .input-group input:focus { outline: none; border-color: #8B5CF6; }
        .error {
            background: rgba(239,68,68,0.1);
            border: 1px solid rgba(239,68,68,0.2);
            border-radius: 10px;
            padding: 10px 14px;
            color: #ef4444;
            font-size: 12px;
            margin-bottom: 16px;
            text-align: center;
        }
        .btn {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #8B5CF6, #6D28D9);
            border: none;
            border-radius: 12px;
            color: #fff;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            transition: 0.3s;
        }
        .btn:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(139,92,246,0.3); }
        .device-id {
            background: rgba(255,255,255,0.03);
            border-radius: 10px;
            padding: 10px 14px;
            margin-bottom: 16px;
            font-family: monospace;
            font-size: 13px;
            color: #8B5CF6;
            text-align: center;
            border: 1px solid rgba(139,92,246,0.1);
        }
        .footer { text-align: center; margin-top: 16px; font-size: 11px; color: #3d2d5a; }
    </style>
</head>
<body>
<div class="login-card">
    <h1>🔐 UNBREAKABLE</h1>
    <p class="sub">100% Secure Authentication</p>
    
    <div class="device-id" id="deviceIdDisplay">Loading...</div>
    
    <% if (error) { %>
        <div class="error"><%= error %></div>
    <% } %>
    
    <form action="/login" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="deviceId" id="deviceIdInput">
        
        <div class="input-group">
            <label>🔑 Access Key</label>
            <input type="password" name="password" placeholder="Enter your access key..." required autocomplete="off">
        </div>
        
        <button type="submit" class="btn">Secure Login</button>
    </form>
    
    <div class="footer">UNBREAKABLE v1.0</div>
</div>

<script>
    (function() {
        let id = sessionStorage.getItem('zx_device_id');
        if (!id) {
            const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
            let newId = 'ZX-';
            for (let i = 0; i < 6; i++) newId += chars[Math.floor(Math.random() * chars.length)];
            id = newId;
            sessionStorage.setItem('zx_device_id', id);
        }
        document.getElementById('deviceIdDisplay').textContent = id;
        document.getElementById('deviceIdInput').value = id;
    })();
</script>
</body>
</html>